# Telegram Bot Token (from @BotFather)
BOT_TOKEN=Bot Token

# Admin Telegram user IDs, comma-separated
ADMIN_IDS=987654321

# Customer support link (shown in /start)
SUPPORT_URL=https://t.me/123

# ---- scpay.q105.cn merchant config ----
PAY_PID=123 
PAY_KEY=1234567

# Payment type: wxpay | alipay | wxpay2 | alipay2 etc.
PAY_TYPE=wxpay

# Your public server URL for receiving payment callbacks
NOTIFY_URL=https://your-domain.com/notify

# Page to redirect after payment (your bot link is fine)
RETURN_URL=https://t.me/your_bot

# HTTP server port for payment callbacks
PORT=3000
